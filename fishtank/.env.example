# Copy to `.env.local` or export before `bun run dev`.
# CORS: run arms with e.g. ARMS_CORS_ALLOW_ORIGIN=http://localhost:3000

VITE_ARMS_URL=http://127.0.0.1:8080
# When arms has MC_API_TOKEN set:
# VITE_ARMS_TOKEN=
# Or when arms uses ARMS_ACL (HTTP Basic):
# VITE_ARMS_BASIC_USER=
# VITE_ARMS_BASIC_PASSWORD=
